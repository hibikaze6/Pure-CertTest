--- Root CA ---

1. openssl genrsa -out ca.key 4096

2. openssl req -new -x509 -days 730 -key ca.key -out ca.crt -subj "/C=JP/O=TestDrive/OU=IT/CN=TestDrive Root CA"

--- KMS Cert ---

3. openssl genrsa -out kms-server.key 4096

4. openssl req -new -key kms-server.key -out kms-server.csr -subj "/C=JP/O=TestDrive/OU=KMS/CN=Windows1.testdrive.local"

5. openssl x509 -req -in kms-server.csr -CA ca.crt -CAkey ca.key -CAcreateserial -out kms-server.crt -days 730 -sha256 -extfile kms-server-ext.cnf

6. openssl pkcs12 -export -out kms-server.p12 -inkey kms-server.key -in kms-server.crt -certfile ca.crt -password pass:password1234

--- Pure Cert ---

7. ssh pureuser@flashblade1.testdrive.local

8. purecert csr create global

9. openssl x509 -req -in global.csr -CA ca.crt -CAkey ca.key -CAcreateserial -out global.crt -days 730 -sha256 -extfile global-ext.cnf

10. purecert setattr --certificate global

--- KMS Start ---

11. ./cosmian_kms.exe --config ./kms.toml

--- Pure KMS Connect ---

12. purecert imported create --ca-certificate localCA

13. purekmip create --ca-certificate localCA --uri Windows1.testdrive.local:5696 Windows1

14. puredns setattr --domain testdrive.local --nameservers 10.0.0.1

15. purekmip test Windows1

